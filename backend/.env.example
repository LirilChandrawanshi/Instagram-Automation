# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/instagram_automation

# Redis and Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Daily limits (human behavior)
DAILY_LIMIT_LIKES=80
DAILY_LIMIT_FOLLOWS=40
DAILY_LIMIT_DMS=20
DAILY_LIMIT_COMMENTS=20

# Optional
DEBUG=false
PLAYWRIGHT_HEADLESS=true
