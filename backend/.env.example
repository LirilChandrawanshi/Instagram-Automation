# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/instagram_automation

# Redis and Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Daily limits (human behavior)
DAILY_LIMIT_LIKES=80
DAILY_LIMIT_FOLLOWS=40
DAILY_LIMIT_DMS=20
DAILY_LIMIT_COMMENTS=20
# Per account per day; one account can run multiple view tasks (multiple views)
DAILY_LIMIT_REEL_VIEWS=9999

# Optional
DEBUG=false
PLAYWRIGHT_HEADLESS=true
# Comma-separated CORS origins (default: localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-app.com

# Instagram Graph API (Business/Creator: DMs + Comments). Get from Meta Developer App.
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=         # Required for webhook X-Hub-Signature-256 verification
# INSTAGRAM_PAGE_ACCESS_TOKEN=   # Page token with instagram_* permissions
# INSTAGRAM_PAGE_ID=             # Facebook Page ID (required for Comment-to-DM Private Reply)
# INSTAGRAM_VERIFY_TOKEN=        # Any string you choose; set same in Meta webhook config
# INSTAGRAM_API_VERSION=v19.0
# INSTAGRAM_COMMENT_DM_KEYWORDS= \b(LINK|EBOOK|PRICE|DM)\b
# INSTAGRAM_COMMENT_DM_REPLY=    We've sent the link to your DMs! Check your inbox.
# When true, only users in the allowed list get the link; others get INSTAGRAM_COMMENT_DM_NON_FOLLOWER_MESSAGE.
# INSTAGRAM_COMMENT_DM_REQUIRE_FOLLOWER=false
# INSTAGRAM_COMMENT_DM_NON_FOLLOWER_MESSAGE= I think you're not following me! Please follow and comment again to get the link.
